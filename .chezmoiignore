# chezmoi ignore rules. Templated by OS — paths listed under a block are
# excluded when that OS condition is true.
#
# Paths are relative to $HOME (target paths), not source paths.
# Pattern syntax is gitignore-style.

# ── Local secrets — never tracked/committed ───────────────────────
.config/fish/conf.d/secrets.fish

# ── Generated by matugen (every OS) — never managed by chezmoi ─────
# These are regenerated from their *-template.* sources by `matugen image`.
.config/starship.toml
.config/kitty/current-theme.conf
.config/tmux/matugen.conf
.config/nvim/lua/matugen.lua

# ── Linux-only (Wayland/X11 stack) — skip on macOS ─────────────────
{{- if ne .chezmoi.os "linux" }}
.config/hypr
.config/niri
.config/noctalia
.config/albert
{{- end }}

# ── macOS-only — skip on Linux ─────────────────────────────────────
{{- if ne .chezmoi.os "darwin" }}
# Add macOS-specific paths here as you create them, e.g.:
# .config/karabiner
# Library/Application Support/...
# Brewfile
{{- end }}
